# =============================================================================
# ZSH Configuration File (.zshrc)
# Structured with modular functions, dependency checks, and auto-updating
# =============================================================================

# Global array to track any missing dependencies
typeset -g -a ZSH_MISSING_CMDS

# --- Function Definitions ---

setup_environment() {
    # Define environment variables and paths
    export LANG=en_US.UTF-8
    export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH
    
    # Automatically change directories if you just type the directory name
    setopt auto_cd
}

setup_history() {
    # Configure history file and limits
    export HISTFILE=~/.histfile
    export HISTSIZE=999999
    export SAVEHIST=999999

    # Apply history best practices
    setopt append_history
    setopt inc_append_history
    setopt share_history
    setopt hist_ignore_dups
    setopt hist_ignore_all_dups
    setopt hist_ignore_space
    setopt extended_glob
    setopt notify
}

setup_completion() {
    # Load and initialize the completion system
    autoload -Uz compinit
    compinit

    # Configure advanced completion styling and behavior
    zstyle ':completion:*' completer _expand _complete _ignored _correct _approximate
    zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
    zstyle ':completion:*' menu select
    zstyle :compinstall filename "$HOME/.zshrc"
}

setup_keybindings() {
    # Apply standard Emacs keybindings
    bindkey -e

    # Home, End, and Delete keys
    bindkey '^[[H'  beginning-of-line
    bindkey '^[OH'  beginning-of-line
    bindkey '^[[F'  end-of-line
    bindkey '^[OF'  end-of-line
    bindkey '^[[3~' delete-char

    # Ctrl + Arrow keys for word jumping
    bindkey '^[[1;5D' backward-word
    bindkey '^[[1;5C' forward-word

    # Alt + Arrow keys for word jumping
    bindkey '^[[1;3D' backward-word
    bindkey '^[[1;3C' forward-word
}

setup_aliases() {
    # Check for flatpak before aliasing codium
    if command -v flatpak &> /dev/null; then
        alias codium="flatpak run com.vscodium.codium "
    else
        ZSH_MISSING_CMDS+=('flatpak')
    fi
    
    # Common quality-of-life aliases for colored and formatted output
    alias ls='ls --color=auto'
    alias ll='ls -lh'
    alias la='ls -lAh'
    alias grep='grep --color=auto'
}

setup_prompt() {
    # Check for starship before initializing
    if command -v starship &> /dev/null; then
        eval "$(starship init zsh)"
    else
        ZSH_MISSING_CMDS+=('starship')
    fi
}

auto_update_dotfiles() {
    # Only run in interactive sessions to avoid breaking non-interactive scripts
    if [[ $- == *i* ]]; then
        # Check for git before attempting to pull
        if command -v git &> /dev/null; then
            
            # Define the location of your dotfiles repository
            # TODO: Change this path to match your actual git repository location
            local dotfiles_repo="$HOME/.dotfiles" 

            # Verify the directory exists and is a valid git repository
            if [[ -d "$dotfiles_repo/.git" ]]; then
                local GREEN='\033[0;32m'
                local YELLOW='\033[0;33m'
                local RED='\033[0;31m'
                local RESET='\033[0m'
                
                echo -e " ${YELLOW}•${RESET} Syncing dotfiles from GitHub..."
                
                # Execute git commands in a subshell '()' to preserve the user's current directory
                (
                    cd "$dotfiles_repo" || exit
                    
                    # Pull changes using rebase to keep history clean.
                    # The 'timeout 5s' command ensures the terminal won't hang if offline.
                    if timeout 5s git pull --quiet --rebase; then
                        echo -e "   ${GREEN}↳${RESET} Dotfiles are up to date."
                    else
                        echo -e "   ${RED}↳${RESET} Sync failed (offline, timeout, or merge conflict)."
                    fi
                )
            fi
        else
            ZSH_MISSING_CMDS+=('git')
        fi
    fi
}

display_welcome_message() {
    # Only display output in interactive sessions
    if [[ $- == *i* ]]; then
        # ANSI color codes
        local GREEN='\033[0;32m'
        local BLUE='\033[0;34m'
        local RED='\033[0;31m'
        local BOLD='\033[1m'
        local RESET='\033[0m'

        echo -e "${BLUE}${BOLD}=======================================${RESET}"
        echo -e "${GREEN}${BOLD}   ZSH Environment Loaded Successfully ${RESET}"
        echo -e "${BLUE}${BOLD}=======================================${RESET}"
        
        # Display status of prompt
        if [[ " ${ZSH_MISSING_CMDS[*]} " =~ " starship " ]]; then
            echo -e " • Starship Prompt: ${RED}Missing${RESET}"
        else
            echo -e " • Starship Prompt: ${GREEN}Active${RESET}"
        fi
        
        echo -e " • Keybindings:     ${GREEN}Configured${RESET}"
        echo -e " • History:         ${GREEN}Optimized${RESET}"

        # Warn if any dependencies are missing
        if (( ${#ZSH_MISSING_CMDS[@]} > 0 )); then
            echo -e "\n ${RED}${BOLD}Warning:${RESET} The following commands are missing:"
            for cmd in "${ZSH_MISSING_CMDS[@]}"; do
                echo -e "   - ${RED}$cmd${RESET}"
            done
        fi
        echo "" # Print a final empty line for clean spacing
    fi
}

# --- Execution ---

# Call all setup functions in the required order
setup_environment
setup_history
setup_completion
setup_keybindings
setup_aliases

# Initialize prompt and sync dotfiles
setup_prompt
auto_update_dotfiles

# Display the beautified output
display_welcome_message

# Cleanup global variables so they don't linger in the shell environment
unset ZSH_MISSING_CMDS
